# Production Environment Variables for soso-delivery.xyz
# Copy this to .env on VPS and update with actual values

###############################################################################
# BACKEND (Laravel) - /var/www/soso-delivery.xyz/backend/.env
###############################################################################

APP_NAME=StackFood
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://soso-delivery.xyz
APP_MODE=live

LOG_CHANNEL=stack
LOG_LEVEL=error

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=stackfood_db
DB_USERNAME=stackfood_user
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD

# Cache & Session
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (optional)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@soso-delivery.xyz
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (if using cloud storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
FILESYSTEM_DRIVER=public

# Payment Gateways
STRIPE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

RAZORPAY_KEY=
RAZORPAY_SECRET=

# SMS Gateway (Twilio)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Google Services
GOOGLE_MAP_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase (Push Notifications)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Social Login
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT=

# OpenAI (if using AI features)
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# Pusher (WebSockets)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

###############################################################################
# FRONTEND (Next.js) - /var/www/soso-delivery.xyz/frontend/.env.local
###############################################################################

# API Configuration
NEXT_PUBLIC_BASE_URL=https://soso-delivery.xyz/api/v1
NEXT_PUBLIC_SOCKET_URL=https://soso-delivery.xyz

# Google Maps
NEXT_PUBLIC_GOOGLE_MAP_KEY=YOUR_GOOGLE_MAP_KEY

# Firebase (must match backend)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Social Login
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_FACEBOOK_APP_ID=

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Payment
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

###############################################################################
# NOTES
###############################################################################

# 1. Generate Laravel APP_KEY with: php artisan key:generate
# 2. Never commit actual .env files to Git
# 3. Use strong passwords for database
# 4. Enable 2FA for all admin accounts
# 5. Keep API keys secure and rotate regularly
# 6. Use environment-specific keys (test vs production)
# 7. Configure CORS properly in Laravel config/cors.php
