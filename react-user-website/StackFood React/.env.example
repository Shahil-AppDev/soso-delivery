# SoSo Delivery - Environment Variables Template
# Copy this file to .env.production and .env.development and fill in the values

# Google Maps API Key (Required)
# Get from: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAP_KEY=your_google_maps_api_key_here

# Backend API URL (Required)
# Your Laravel backend URL
NEXT_PUBLIC_BASE_URL=https://soso-delivery.xyz

# Client Host URL (Required)
# For development: http://localhost:3000
# For production: Your Vercel deployment URL
NEXT_CLIENT_HOST_URL=http://localhost:3000

# Site Version
NEXT_PUBLIC_SITE_VERSION=3.4
